# =============================================================================
# LLM-Powered AI QA Suite — environment template
#
# Usage:
#   1. Copy this file to .env:       cp .env.example .env
#   2. Fill in your ANTHROPIC_API_KEY (required)
#   3. Optionally override other settings below
# =============================================================================

# ------ REQUIRED ------

# Anthropic API key (get from https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME_WITH_YOUR_KEY

# ------ OPTIONAL: Anthropic model + tokens ------

# Model ID (default: claude-opus-4-6)
# Options: claude-opus-4-6, claude-sonnet-4-6, claude-haiku-4-5
# CLAUDE_MODEL=claude-opus-4-6

# Max output tokens per call (default: 4096)
# CLAUDE_MAX_TOKENS=4096

# HTTP timeout in seconds (default: 60)
# CLAUDE_TIMEOUT_SECONDS=60

# ------ OPTIONAL: Retry behavior ------

# RETRY_MAX_ATTEMPTS=3
# RETRY_WAIT_MIN_SECONDS=1.0
# RETRY_WAIT_MAX_SECONDS=10.0

# ------ OPTIONAL: Database path ------

# SQLite file location (default: ~/ai-qa-projects/qa_suite.db)
# DB_PATH=/absolute/path/to/qa_suite.db

# ------ OPTIONAL: Agent prompts directory ------

# Path containing agent prompt files (SDET.MD, CODE_REVIEW.MD, ARCHITECT.MD, SECURITY.MD)
# Required by: ai-debug-accelerator, ai-mock-architect
# Default: ~/ai-agents/prompts
# PROMPTS_DIR=/absolute/path/to/prompts

# ------ OPTIONAL: Generator defaults ------

# GENERATOR_DEFAULT_FRAMEWORK=playwright
# GENERATOR_OUTPUT_DIR=./generated

# ------ OPTIONAL: Analyzer threshold ------

# Flaky test fail-rate threshold in percent (default: 20.0)
# ANALYZER_FLAKY_THRESHOLD_PERCENT=20.0

# ------ OPTIONAL: Dashboard ------

# DASHBOARD_HOST=127.0.0.1
# DASHBOARD_PORT=8000

# ------ OPTIONAL: Logging ------

# LOG_LEVEL=INFO
# LOG_JSON=true
